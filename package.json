{
  "name": "dayjavu",
  "author": "johkade.dev@gmail.com",
  "version": "0.2.1",
  "description": "Type-safe date utilities with timezone and locale enforcement",
  "keywords": ["date", "timezone", "locale", "date-fns", "typescript"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "date-fns": ">=3.0.0",
    "date-fns-tz": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
